generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Candle {
    id          String      @id     @default(uuid())
    symbol      String
    timestamp   DateTime
    open        Decimal
    high        Decimal
    low         Decimal
    close       Decimal
    volume      Decimal

    @@unique([symbol, timestamp])
}

model Sentiment {
    id              String          @id     @default(uuid())
    source          String
    title           String
    sentiment       String
    score           Int
    reasoning       String?
    timestamp       DateTime        @default(now())
}

model TradeSimulation {
    id              String          @id     @default(uuid())
    symbol          String
    action          String
    price           Decimal
    timestamp       DateTime        @default(now())
    metadata        Json
}

model ActivePosition {
  id                String      @id     @default(uuid())
  symbol            String      @unique
  entryPrice        Float
  amount            Float
  stopLossPrice     Float
  takeProfitPrice   Float
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model MarketConfig {
    id              String      @id     @default(uuid())
    symbol          String      @unique
    isActive        Boolean     @default(true)
    timeframe       String      @default("15m")
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt
}
